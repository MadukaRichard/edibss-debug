PORT=5003

# MongoDB Atlas connection string (see README "Set up a real database" section)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/medirun?retryWrites=true&w=majority

JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRE=30d
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Firebase Admin SDK — used to verify "Sign in with Google" tokens sent from the
# frontend. Get these three values from Firebase Console > Project settings >
# Service accounts > Generate new private key (see README for full steps).
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
